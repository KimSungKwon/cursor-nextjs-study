## 4. Props 인터페이스 설계

### AdminSidebar (신규)

```ts
interface AdminSidebarItem {
  id: string;
  label: string;
  href: string;
  icon?: ReactNode;
  badgeCount?: number;
  children?: AdminSidebarItem[];
}

interface AdminSidebarSection {
  id: string;
  title: string; // MAIN MENU | PRODUCTS | ADMIN
  items: AdminSidebarItem[];
}

interface AdminSidebarProps {
  logoText?: string; // "Cursor Commerce"
  sections: AdminSidebarSection[];
  activeId?: string;
  collapsed?: boolean;
  onToggleCollapse?: () => void;
  onNavigate?: (id: string, href: string) => void;
  className?: string;
}
```

### AdminLayout (확장/신규)

```ts
interface AdminLayoutProps {
  children: ReactNode;
  sidebar?: ReactNode;
  topbar?: ReactNode;
  className?: string;
}
```

### AdminHeader (신규 — AdminPageHeader 확장)

```ts
interface AdminHeaderProps {
  title: string;
  description?: string;
  actions?: ReactNode;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  className?: string;
}
```

### AdminTopbar (신규, 선택)

```ts
interface AdminTopbarProps {
  searchSlot?: ReactNode;
  rightSlot?: ReactNode; // 알림/유저
  className?: string;
}
```

### AdminFilterBar (신규)

```ts
interface AdminFilterBarProps {
  searchPlaceholder?: string; // "Search by order id"
  searchValue?: string;
  onSearchChange?: (value: string) => void;
  dateRangeLabel?: string; // "Filter by date range"
  dateRangeOptions?: Array<{ value: string; label: string }>;
  dateRangeValue?: string;
  onDateRangeChange?: (value: string) => void;
  extraFilters?: ReactNode;
  className?: string;
}
```

### AdminTable (신규)

```ts
interface AdminTableColumn<T> {
  id: string;
  header: string;
  width?: number | string;
  align?: "left" | "center" | "right";
  cell: (row: T) => ReactNode;
}

interface AdminTableProps<T> {
  columns: AdminTableColumn<T>[];
  rows: T[];
  rowKey: (row: T) => string;
  isLoading?: boolean;
  emptyMessage?: string;
  onRowClick?: (row: T) => void;
  className?: string;
}
```

### AdminTablePagination (신규)

```ts
interface AdminTablePaginationProps {
  page: number;
  totalPages: number;
  pageSize: number;
  totalItems: number;
  pageSizeOptions?: number[]; // [10, 25, 50]
  onPageChange?: (page: number) => void;
  onPageSizeChange?: (size: number) => void;
  className?: string;
}
```

### AdminStatusBadge (신규)

```ts
type AdminStatus = "active" | "inactive" | "pending" | "error";

interface AdminStatusBadgeProps {
  status: AdminStatus;
  label?: string; // 미지정 시 status 기본 라벨
  className?: string;
}
```

### AdminMetricCard (신규 — 보드 외 설계)

```ts
interface AdminMetricCardProps {
  title: string;
  value: string | number;
  delta?: string; // "+12%"
  deltaTone?: "up" | "down" | "neutral";
  icon?: ReactNode;
  className?: string;
}
```

### SettingsSwitch / SettingsCard (Settings 페이지용, 보조)

```ts
interface AdminSwitchProps {
  checked: boolean;
  onChange?: (checked: boolean) => void;
  disabled?: boolean;
  "aria-label": string;
  className?: string;
}

interface AdminSettingsCardProps {
  title: string;
  description?: string;
  icon?: ReactNode;
  enabled: boolean;
  onEnabledChange?: (enabled: boolean) => void;
  children?: ReactNode; // threshold input 등
  className?: string;
}
```

