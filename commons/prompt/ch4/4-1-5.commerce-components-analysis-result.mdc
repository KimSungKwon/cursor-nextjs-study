## 4. Props 인터페이스 설계

### ProductCard (신규)

```ts
interface ProductCardProps {
  product: Product; // id, name, price, salePrice?, imageUrl, rating?, isLiked?
  isNew?: boolean;
  discountPercent?: number; // -50% 뱃지
  onAddToCart?: (productId: string) => void;
  onToggleWishlist?: (productId: string) => void;
  onClick?: (productId: string) => void;
  className?: string;
}
```

### ProductGrid (신규)

```ts
interface ProductGridProps {
  products: Product[];
  columns?: 2 | 3 | 4; // 기본 4 (카드 262폭 기준)
  gap?: number; // 기본 24
  isLoading?: boolean;
  emptyMessage?: string;
  onAddToCart?: (productId: string) => void;
  onToggleWishlist?: (productId: string) => void;
  className?: string;
}
```

### CartItemRow (신규)

```ts
interface CartItemRowProps {
  item: {
    productId: string;
    name: string;
    imageUrl: string;
    optionLabel?: string; // "Color: Black"
    unitPrice: number;
    quantity: number;
  };
  onQuantityChange?: (productId: string, quantity: number) => void;
  onRemove?: (productId: string) => void;
  className?: string;
}
```

### RatingStars (신규)

```ts
interface RatingStarsProps {
  value: number; // 0–5, 소수점 허용 시 floor 표시
  max?: number; // 기본 5
  size?: number; // 기본 16
  readOnly?: boolean; // 기본 true
  onChange?: (value: number) => void;
  className?: string;
}
```

### ReviewCard (신규)

```ts
interface ReviewCardProps {
  authorName: string;
  avatarUrl?: string;
  rating: number;
  body: string;
  className?: string;
}
```

### QuantitySelector (신규)

```ts
interface QuantitySelectorProps {
  value: number;
  min?: number; // 기본 1
  max?: number;
  size?: "sm" | "md"; // sm: 80×32(장바구니), md: 127×52(상세)
  disabled?: boolean;
  onChange?: (value: number) => void;
  className?: string;
}
```

### OrderSummaryPanel (신규)

```ts
interface OrderSummaryPanelProps {
  subtotal: number;
  shippingOptions?: Array<{
    id: string;
    label: string; // "Free shipping"
    price: number;
  }>;
  selectedShippingId?: string;
  onShippingChange?: (id: string) => void;
  total: number;
  ctaLabel?: string; // "Checkout" 등
  onCheckout?: () => void;
  className?: string;
}
```

